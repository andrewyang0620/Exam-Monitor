{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@tcf-tracker/types": ["../../packages/types/src/index.ts"],
      "@tcf-tracker/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
