{
  "manifest_version": 3,
  "name": "ExamSeat Monitor",
  "version": "1.0.0",
  "description": "Monitors TEF/TCF Canada exam seat availability and autofills registration forms from your local profile. Final submission is always manual.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "icons/icon-32.png",
    "default_title": "ExamSeat Monitor"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.alliancefrancaise.ca/*",
        "https://alliancefrancaise.ca/*",
        "https://www.afvancouver.com/*",
        "https://afvancouver.com/*",
        "https://www.eventbrite.ca/*",
        "https://www.eventbrite.com/*",
        "https://www.clic.ulaval.ca/*",
        "https://clic.ulaval.ca/*",
        "https://www.alliance-francaise.ca/*",
        "https://af-toronto.ca/*"
      ],
      "js": ["src/content/content.ts"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.alliancefrancaise.ca/*",
    "https://alliancefrancaise.ca/*",
    "https://www.afvancouver.com/*",
    "https://afvancouver.com/*",
    "https://www.eventbrite.ca/*",
    "https://www.eventbrite.com/*",
    "https://www.clic.ulaval.ca/*",
    "https://clic.ulaval.ca/*",
    "https://af-toronto.ca/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
