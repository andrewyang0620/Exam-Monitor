# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — NEVER expose to the browser; used in API routes only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Monitor pipeline ─────────────────────────────────────────────────────────
# Secret for POST /api/monitor — pass as header: x-monitor-secret: <value>
# Generate with: openssl rand -hex 32
MONITOR_API_SECRET=change-me-generate-a-real-secret
# Vercel Cron auth secret — must match CRON_SECRET in Vercel project settings
CRON_SECRET=change-me-generate-a-real-secret
# Dev-only: set to same value as MONITOR_API_SECRET to enable auto-monitor in local dev
# NOT needed in production (Vercel Cron handles it)
NEXT_PUBLIC_DEV_MONITOR_SECRET=

# ─── Email notifications (Resend) ─────────────────────────────────────────────
# https://resend.com — free tier: 100 emails/day
# If not set, emails are skipped silently (console.log only)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=ExamSeat Monitor <noreply@examseats.app>

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to bypass Supabase and serve mock data from mock-data.ts
# Required when Supabase credentials are not set
NEXT_PUBLIC_DEMO_MODE=false

# ─── Feature flags ────────────────────────────────────────────────────────────
# SMS notifications — not implemented in V1
NEXT_PUBLIC_SMS_ENABLED=false
